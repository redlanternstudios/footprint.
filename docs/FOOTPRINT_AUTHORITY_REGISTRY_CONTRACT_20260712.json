{
  "contract_version": "1.0",
  "status": "superseded_by_scope_v2_20260713",
  "purpose": "Machine enforceable authority and truth contract for Footprint",
  "activation_default": "deny",
  "source_priority": [
    "bridge_current_state",
    "authority_registry",
    "truthcal_receipt",
    "verified_public_artifact",
    "memory_snapshot",
    "external_signal"
  ],
  "capability_states": [
    "proven",
    "demonstrated",
    "building",
    "exploring",
    "blocked",
    "private"
  ],
  "claim_ceilings": {
    "proven": ["shipped", "verified", "available"],
    "demonstrated": ["working_demo", "tested_in_bounded_context"],
    "building": ["building", "testing", "in_progress"],
    "exploring": ["exploring", "researching", "designing"],
    "blocked": ["blocked", "learning_from_blocker"],
    "private": []
  },
  "decision_outcomes": [
    "publish",
